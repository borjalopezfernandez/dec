<?xml version="1.0" encoding="UTF-8"?>

<Config>

   <!-- =========================================================== -->

   <ListInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">


      <Interface>
         <Name>IERS_BULA</Name>
         <LocalInbox>/data/fcops/int/bula</LocalInbox>
         <DownloadDirs>
            <Directory DepthSearch="0">%Q{/data/xml/bulletina-#{RomanNumerals.to_roman(Time.new.strftime("%y").to_i+13).downcase}-#{(Time.new.strftime("%U").to_i-1).to_s.rjust(3,'0')}.xml}</Directory>
            <Directory DepthSearch="0">/data/latestVersion/bulletinA.txt</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>false</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>true</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>true</MD5>
         </Switches>
      </Interface>

   <Interface>
         <Name>IERS_BULB</Name>
         <LocalInbox>/data/fcops/int/bulb</LocalInbox>
         <DownloadDirs>
            <Directory DepthSearch="0">/data/latestVersion/bulletinB.txt</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>false</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>true</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>true</MD5>
         </Switches>
      </Interface>

     <Interface>
         <Name>NASA_NBULA</Name>
         <LocalInbox>/data/fcops/int/bula</LocalInbox>
         <DownloadDirs>
		      <Directory DepthSearch="0">/archive/products/iers/finals2000A.data</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>false</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>false</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>true</MD5>
         </Switches>         
      </Interface>

      <Interface>
         <Name>IERS_BULB_BCKP</Name>
         <LocalInbox>/data/fcops/int/bulb</LocalInbox>
         <DownloadDirs>
		      <Directory DepthSearch="0">/iers/bul/bulb_new/bulletinb.dat</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>false</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>true</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>true</MD5>
         </Switches>         
      </Interface>

   </ListInterfaces>

   <!-- =========================================================== -->

   <DownloadRules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
 
      <File Type="*NPPF*">
         <Description>MPL_NPPF__</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*DNPPF*">
         <Description>MPL_DNPPF_</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*MPL_GS_PLN*">
         <Description>MPL_GS_PLN</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*MPL_GS_CNF*">
         <Description>MPL_GS_CNF</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*MPL_ORBPRE*">
         <Description>MPL_ORBPRE</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*REP_NOB_IN*">
         <Description>REP_NOB_IN</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*REP_NOBOUT*">
         <Description>REP_NOBOUT</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*REP__CHF__*">
         <Description>REP__CHF__</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*REP_PSDUMP*">
         <Description>REP_PSDUMP</Description>
         <FromList>
            <Interface>MPF_2_SMF</Interface>
         </FromList>
      </File>

   <File Type="finals2000A.data">
         <Description>AUX_NBULA_</Description>
         <FromList>
            <Interface>NASA_NBULA</Interface>
         </FromList>
      </File>

      <File Type="bulletinA.txt">
         <Description>AUX_ERP_RD</Description>
         <FromList>
            <Interface>IERS_BULA</Interface>
         </FromList>
      </File>

      <File Type="bulletinB.txt">
         <Description>AUX_ERP_RD</Description>
         <FromList>
            <Interface>IERS_BULB</Interface>
         </FromList>
      </File>

      <File Type="bulletinb.dat">
         <Description>AUX_ERP_RD</Description>
         <FromList>
            <Interface>IERS_BULB_BCKP</Interface>
         </FromList>
      </File>

      <File Type="bulletina*.xml">
         <Description>AUX_ERP_RD</Description>
         <FromList>
            <Interface>IERS_BULA</Interface>
         </FromList>
      </File>


      <File Type="ser7.dat">
         <Description>NASA IERS bulletin C</Description>
         <FromList>
            <Interface>S2_CDDIS_IERS_4_AUX_UT1UTC</Interface>
         </FromList>
      </File>

      

   </DownloadRules>

   <!-- =========================================================== -->

   <DisseminationRules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
   
      <ListIntrays>

         <Intray>
            <Name>S1X_IN_4_AUX_TEC</Name>
            <Directory>/data/adgs/tmp/in_basket_if_s1_cddis_4_aux_tec/s1x</Directory>
            <Execute>auxConverter -m S1 -f %F -d /data/adgs/arc/intray</Execute>
         </Intray>

         <Intray>
            <Name>BIOMASS_ECHO_AUX_TEC</Name>
            <Directory>/tmp/adgs/tmp/in_basket_if_s1_cddis_4_aux_tec/biomass1</Directory>
            <Execute>echo %f</Execute>
         </Intray>

         <Intray>
            <Name>BIOMASS_ECHO_FULLPATH_AUX_TEC</Name>
            <Directory>/tmp/adgs/tmp/in_basket_if_s1_cddis_4_aux_tec/biomass3</Directory>
            <Execute>echo %F</Execute>
         </Intray>


         <Intray>
            <Name>BIOMASS_LIST_AUX_TEC</Name>
            <Directory>/tmp/adgs/tmp/in_basket_if_s1_cddis_4_aux_tec/biomass2</Directory>
            <Execute>ls -l %F</Execute>
         </Intray>

         <Intray>
            <Name>S3_IN</Name>
            <Directory>/data/adgs/dec/s3_aux</Directory>
            <!--
            <Execute>auxConverter -f %F -d /tmp/aux_tmp</Execute>
            -->
         </Intray>

         <Intray>
            <Name>MINARC_IN</Name>
            <Directory>/data/adgs/arc/intray</Directory>
            <!--
            <Execute>auxConverter -f %F -d /tmp/aux_tmp</Execute>
            -->
         </Intray>

         <Intray>
            <Name>S1_IN</Name>
            <Directory>/tmp/dec_local_dissemination/s1/</Directory>
            <!--
            <Execute>auxConverter -f %F -d /tmp/aux_tmp</Execute>
            -->
         </Intray>
                
      </ListIntrays>

      <!-- =============================================== -->

      <ListFilesDisseminated>
    
      <!--
            SORT Rules ranking from more restrictive ones    
            Only the first rule matching the file pattern is applied     
      -->


      </ListFilesDisseminated>
   </DisseminationRules>

   <!-- =========================================================== -->


</Config>
