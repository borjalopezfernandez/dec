<Config>

<!-- 

Rules for the new kids

-->

   <!-- =========================================================== -->

   <ListInterfaces xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

     <Interface>
         <Name>MPF_2_SMF</Name>
         <LocalInbox>/data/fcops/int/fromMPF</LocalInbox>
         <DownloadDirs>
            <Directory DepthSearch="0">/data/mpf/delivery_root/smf/fromMPF</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>true</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>false</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>false</MD5>
         </Switches>
      </Interface>

      <Interface>
         <Name>CPF_2_SMF</Name>
         <LocalInbox>/data/fcops/int/fromCPF</LocalInbox>
         <DownloadDirs>
            <Directory DepthSearch="0">smf</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>true</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>false</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>false</MD5>
         </Switches>
      </Interface>
     
     <Interface>
         <Name>MARF_2_SMF</Name>
         <LocalInbox>/data/fcops/int/fromMARF</LocalInbox>
         <DownloadDirs>
            <Directory DepthSearch="0">.</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>true</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>false</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>false</MD5>
         </Switches>
      </Interface>

      <Interface>
         <Name>AF_2_SMF</Name>
         <LocalInbox>/data/fcops/int/fromAF</LocalInbox>
         <DownloadDirs>
            <Directory DepthSearch="0">toSMF</Directory>
         </DownloadDirs>
         <Switches>
            <DeleteDownloaded>true</DeleteDownloaded>
            <DeleteDuplicated>false</DeleteDuplicated>
            <DeleteUnknown>false</DeleteUnknown>
            <LocalDissemination>false</LocalDissemination>
            <LogDuplicated>false</LogDuplicated>
            <LogUnknown>false</LogUnknown>
            <MD5>false</MD5>
         </Switches>
      </Interface>

      <Interface>
         <Name>DAF_2_SMF</Name>
