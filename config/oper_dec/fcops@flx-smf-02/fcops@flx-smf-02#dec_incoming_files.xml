   <!-- =========================================================== -->

   <DownloadRules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
 

<!--

     <File Type="bulletinA.txt">
         <Description>AUX_IERS_A</Description>
         <FromList>
            <Interface>IERS_BULA</Interface>
         </FromList>
      </File>
 
      <File Type="bulletinB.txt">
         <Description>AUX_IERS_B</Description>
         <FromList>
            <Interface>IERS_BULB</Interface>
         </FromList>
      </File>

-->

      <File Type="*DWHDATA_OA*">
         <Description>AUX_IERS_A</Description>
         <FromList>
            <Interface>DAF_2_SMF</Interface>
         </FromList>
      </File>

      <File Type="*REP_XACQ*">
