<Interface Name="MPF_2_SMF">
  <Desc>MPF 2 SMF</Desc>
  <TXRXParams>
    <Enabled4Sending>false</Enabled4Sending>
    <Enabled4Receiving>true</Enabled4Receiving>
    <ImmediateRetries>3</ImmediateRetries>
    <LoopRetries>2</LoopRetries>
    <LoopDelay unit="s">60</LoopDelay>
    <PollingInterval unit="s">20</PollingInterval>
    <PollingSize>100000</PollingSize>
    <ParallelDownload>8</ParallelDownload>
  </TXRXParams>    
  <Server>
    <Protocol>SFTP</Protocol>
    <Hostname>172.29.222.2</Hostname>
    <Port>22</Port>
    <User>mpsoper</User>
    <Pass></Pass>
    <RegisterContentFlag>false</RegisterContentFlag>
    <RetrieveContentFlag>true</RetrieveContentFlag>
    <SecureFlag>true</SecureFlag>
    <VerifyPeerSSL>false</VerifyPeerSSL>
    <CompressFlag>false</CompressFlag>
    <PassiveFlag>true</PassiveFlag>
    <CleanUpFreq Unit="s">5</CleanUpFreq>
  </Server>
  <DeliverByMailTo>
     <Address></Address>
  </DeliverByMailTo>
  <Notify>
    <SendNotification>false</SendNotification>
    <To>
     <Address></Address>
    </To>
  </Notify>
  <Events>
      <Event Name='OnReceiveNewFilesOK'     executeCmd="decSend2Interface -m SMF_PDGS_MPF"/>
      <Event Name='OnReceiveOK'             executeCmd="decSend2Interface -m SMF_PDGS_MPF"/>
      <!--
      <Event Name='OnReceiveNewFile'        executeCmd="echo 'OnReceiveNewFile from SMF_PDGS'"/>
      <Event Name='NewFile2Intray'          executeCmd="echo 'NewFile2Intray from SMF_PDGS %f / %F'"/>
      -->
  </Events>
  <ContactInfo>
    <Name></Name>
    <EMail></EMail>
    <Tel></Tel>
    <Fax></Fax>
    <Address></Address>
  </ContactInfo>
</Interface> 

